########################
# Allgemein
########################
TZ=Europe/Berlin

# Host-Basisverzeichnis für alle Containerdaten
DOCKER_ROOT=/srv/docker

########################
# Jellyfin (LinuxServer.io oder offizielles Image)
########################

# Linux-User/Gruppen IDs (damit Jellyfin auf deine Medien zugreifen darf)
# id -u und id -g auf dem Host ausführen und hier eintragen
JELLYFIN_PUID=1000
JELLYFIN_PGID=1000

# Öffentliche URL unter der Jellyfin erreichbar ist (für Apps/Autodiscovery)
JELLYFIN_PUBLIC_URL=https://jellyfin.example.com

# Basisverzeichnisse auf dem Host
JELLYFIN_CONFIG_DIR=${DOCKER_ROOT}/jellyfin/config
JELLYFIN_CACHE_DIR=${DOCKER_ROOT}/jellyfin/cache
JELLYFIN_TRANSCODE_DIR=${DOCKER_ROOT}/jellyfin/transcode

# Medienpfade (Host)
JELLYFIN_MOVIES_DIR=/srv/media/movies
JELLYFIN_SHOWS_DIR=/srv/media/shows
JELLYFIN_MUSIC_DIR=/srv/media/music

# Optional: Logs separat halten
JELLYFIN_LOG_DIR=${JELLYFIN_CACHE_DIR}/log

########################
# Jellyseerr / Seerr (Requests für Jellyfin)
########################

# Container-Zeitzone
JELLYSEERR_TZ=Europe/Berlin

# Log-Level für Jellyseerr (debug|info|warn|error)
JELLYSEERR_LOG_LEVEL=info

# Host- und Pfadangaben
JELLYSEERR_CONFIG_DIR=${DOCKER_ROOT}/jellyseerr/config
JELLYSEERR_HTTP_PORT=5055

# Externe URL, unter der Jellyseerr später erreichbar ist
JELLYSEERR_PUBLIC_URL=https://requests.example.com

########################
# Integration: Jellyfin, TMDB, Radarr, Sonarr
# (werden in der Regel im Web-UI eingetragen,
# hier nur als zentrale, geheime Variablen)
########################

# Jellyfin API-Key (in Jellyfin unter Dashboard -> API-Schlüssel erzeugen)
JELLYFIN_API_KEY=DEIN_JELLYFIN_API_KEY_HIER

# TMDB-API-Key für Metadata (https://www.themoviedb.org/)
TMDB_API_KEY=DEIN_TMDB_API_KEY_HIER

# Radarr/Sonarr API-Keys – aus den jeweiligen UIs kopieren
RADARR_API_KEY=DEIN_RADARR_API_KEY
SONARR_API_KEY=DEIN_SONARR_API_KEY

# Radarr/Sonarr interne URLs im Docker-Netz (Service-Namen in compose)
RADARR_URL=http://radarr:7878
SONARR_URL=http://sonarr:8989

########################
# Datenbank (optional, falls Seerr/Jellyseerr externen DB-Backends nutzen würde)
# -> aktuell nutzen Overseerr/Jellyseerr standardmäßig SQLite im Config-Ordner.
#   Diese Variablen sind eher Platzhalter für eigene Erweiterungen.
########################

DB_HOST=postgres
DB_PORT=5432
DB_USER=media
DB_PASSWORD=STRONG_PASSWORD_HERE
DB_NAME=media_requests
